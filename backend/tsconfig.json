{
  "include": [
    "server/**/*",
    "shared/**/*",
    "drizzle/**/*"
, "tests/routers/auth.test.ts", "tests/routers/users.test.ts"  ],

  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ],

  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "strict": true,

    "lib": ["ES2022", "DOM"],

    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,

    "moduleResolution": "bundler",

    "types": ["node"],

    "paths": {
      "@shared/*": ["./shared/*"]
    }
  }
}